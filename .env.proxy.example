# =====================================================
# RESIDENTIAL PROXY CONFIGURATION
# =====================================================
# This file contains example configuration for residential proxy integration.
# Copy to .env and fill in your actual proxy credentials.
#
# SECURITY WARNING:
# - Never commit real credentials to version control
# - Use environment variable management in production
# - Rotate credentials regularly
# - Monitor proxy usage for unauthorized access
# =====================================================

# Residential Proxy Service Credentials
# Example using BrightData (formerly Luminati)
RESIDENTIAL_PROXY_HOST=brd.superproxy.io
RESIDENTIAL_PROXY_PORT=33335
RESIDENTIAL_PROXY_USER=your-username
RESIDENTIAL_PROXY_PASS=your-password

# Environment (development|staging|production)
# Proxy usage is restricted to staging and testing environments
NODE_ENV=staging

# Enable detailed proxy logging for debugging
# Set to 'true' only during development/debugging
PROXY_DEBUG_LOGGING=false

# Database and other existing config
DB_CONNECTION_STRING=your-connection-string

# Example endpoints that can use proxy:
# - geo-validation: Geo-location validation testing
# - ip-reputation: IP reputation service checks
# - regional-content: Regional content delivery validation
# - third-party-validation: Third-party service compatibility testing
#
# Rate limits per endpoint per minute:
# - geo-validation: 10 requests/minute
# - ip-reputation: 5 requests/minute
# - regional-content: 15 requests/minute
# - third-party-validation: 8 requests/minute
